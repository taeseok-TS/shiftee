# ─────────────────────────────────────────────────────────────
# 큐브티 배포용 환경변수 예시.
# 이 파일을 복사해서 .env 로 만들고 실제 값으로 채우세요:
#   cp .env.docker.example .env
# docker compose 가 같은 폴더의 .env 를 자동으로 읽습니다.
# ─────────────────────────────────────────────────────────────

# PostgreSQL (컨테이너 내부 DB)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=여기에_강력한_비밀번호
POSTGRES_DB=shiftee

# JWT 시크릿 (최소 32자 랜덤 문자열)
#   생성 예: openssl rand -base64 48
JWT_SECRET=여기에_랜덤_시크릿_최소_32자

# 외부에서 접속할 실제 주소 (도메인 또는 서버 IP)
NEXT_PUBLIC_APP_URL=https://cubetee.example.com
NEXT_PUBLIC_API_URL=https://cubetee.example.com/api

# 이메일 발송(SMTP)을 쓰는 경우만 채우세요
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=앱비밀번호
