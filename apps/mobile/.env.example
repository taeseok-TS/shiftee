# 큐브티 모바일 환경변수 예시
# 이 파일을 복사해서 .env 로 만들고 값을 채우세요:  cp .env.example .env
# (Expo 는 EXPO_PUBLIC_ 접두사 변수만 앱 코드에서 읽을 수 있습니다)

# API 서버 주소
#  - 안드로이드 에뮬레이터:       http://10.0.2.2:3000/api
#  - iOS 시뮬레이터 / 웹:        http://localhost:3000/api
#  - 실기기(같은 와이파이):       http://<PC의_LAN_IP>:3000/api   예) http://192.168.0.10:3000/api
#  - 온라인 배포 후:             https://qubetee.example.com/api
EXPO_PUBLIC_API_URL=http://localhost:3000/api
